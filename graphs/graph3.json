{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "",
  "width": 480,
  "height": 340,
  "data": {
    "url": "data/australia_unemployment_trend_salm.csv"
  },
  "transform": [
    {
      "calculate": "datum.quarter === 'Mar-21' ? 'COVID peak' : (datum.quarter === 'Jun-23' ? '15-year low' : null)",
      "as": "milestone"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.5,
        "color": "#d4b876"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Year",
          "axis": {
            "format": "%Y",
            "labelAngle": 0
          }
        },
        "y": {
          "field": "unemployment_rate",
          "type": "quantitative",
          "title": "Unemployment Rate (%)",
          "scale": {
            "zero": false
          }
        },
        "tooltip": [
          {
            "field": "quarter",
            "type": "nominal",
            "title": "Quarter"
          },
          {
            "field": "unemployment_rate",
            "type": "quantitative",
            "title": "Unemployment Rate (%)",
            "format": ".2f"
          },
          {
            "field": "unemployed_persons",
            "type": "quantitative",
            "title": "Unemployed Persons",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.milestone !== null"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 160,
        "stroke": "#161616",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "unemployment_rate",
          "type": "quantitative"
        },
        "color": {
          "field": "milestone",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "COVID peak",
              "15-year low"
            ],
            "range": [
              "#e07a4a",
              "#e8c87a"
            ]
          },
          "legend": {
            "orient": "top-right",
            "offset": -5,
            "symbolSize": 100,
            "padding": 8
          }
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.quarter === 'Mar-21'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 8,
        "dy": -8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#e07a4a"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "unemployment_rate",
          "type": "quantitative"
        },
        "text": {
          "value": "6.63%"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.quarter === 'Jun-23'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 12,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#e8c87a"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "unemployment_rate",
          "type": "quantitative"
        },
        "text": {
          "value": "3.59%"
        }
      }
    }
  ],
  "config": {
    "background": "#161616",
    "font": "Source Sans 3",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "labelColor": "#c4bfb5",
      "titleColor": "#f4f1ea",
      "domainColor": "#2a2a2a",
      "tickColor": "#a8a08e",
      "gridColor": "#222222",
      "gridOpacity": 0.5,
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "labelColor": "#c4bfb5",
      "titleColor": "#f4f1ea",
      "labelFontSize": 10,
      "symbolType": "circle"
    },
    "text": {
      "font": "Source Sans 3",
      "color": "#f4f1ea"
    }
  }
}