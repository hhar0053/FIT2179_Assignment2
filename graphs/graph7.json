{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "",
  "width": 790,
  "height": 360,
  "data": {
    "url": "data/labour_force_status_by_qualification_persons_2025.csv"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "qualification_group",
      "type": "nominal",
      "sort": [
        "Bachelor Degree",
        "Certificate III/IV",
        "Without a Non-school Qualification"
      ],
      "title": "Qualification Group",
      "axis": {
        "labelLimit": 320
      }
    },
    "x": {
      "field": "percentage",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Share of People Aged 15–74 (%)",
      "axis": {
        "format": ".0%"
      }
    },
    "color": {
      "field": "labour_force_status",
      "type": "nominal",
      "sort": [
        "Employed Full-time",
        "Employed Part-time",
        "Unemployed",
        "Not in Labour Force"
      ],
      "title": "Labour Force Status",
      "scale": {
        "domain": [
          "Employed Full-time",
          "Employed Part-time",
          "Not in Labour Force",
          "Unemployed"
        ],
        "range": [
          "#2563A6",
          "#7FB3E6",
          "#C7D2E3",
          "#D46A6A"
        ]
      }
    },
    "order": {
      "field": "labour_force_status",
      "sort": "ascending"
    },
    "tooltip": [
      {
        "field": "qualification_group",
        "type": "nominal",
        "title": "Qualification Group"
      },
      {
        "field": "labour_force_status",
        "type": "nominal",
        "title": "Labour Force Status"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Percentage",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "font": "Source Sans 3",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom",
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    }
  }
}
