{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "",
  "width": 430,
  "height": 360,
  "data": {
    "url": "data/participation_trend_march_2016_2026.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Year",
          "axis": {
            "format": "%Y"
          }
        },
        "y": {
          "field": "participation_rate",
          "type": "quantitative",
          "title": "Participation Rate (%)",
          "scale": {
            "zero": false
          }
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },
        "y": {
          "field": "participation_rate",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Date",
            "format": "%b %Y"
          },
          {
            "field": "participation_rate",
            "type": "quantitative",
            "title": "Participation Rate (%)",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "font": "Source Sans 3",
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": null
    }
  }
}
