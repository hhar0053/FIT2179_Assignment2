{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 480,
  "height": 320,
  "data": {
    "url": "data/participation_trend_march_2016_2026.csv"
  },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Year",
      "axis": {
        "format": "%Y",
        "labelAngle": 0,
        "tickCount": 6
      }
    },
    "y": {
      "field": "participation_rate",
      "type": "quantitative",
      "title": "Participation Rate (%)",
      "scale": {
        "domain": [
          64,
          68
        ],
        "zero": false,
        "nice": false
      },
      "axis": {
        "format": ".1f",
        "grid": true
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#c9a961",
        "opacity": 0.28,
        "interpolate": "monotone"
      },
      "encoding": {
        "y2": {
          "datum": 64
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#f1d27a",
        "strokeWidth": 4,
        "interpolate": "monotone"
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 85,
        "color": "#f1d27a",
        "stroke": "#0a0a0a",
        "strokeWidth": 1.5
      },
      "encoding": {
        "tooltip": [
          {
            "field": "period",
            "type": "nominal",
            "title": "Period"
          },
          {
            "field": "participation_rate",
            "type": "quantitative",
            "title": "Participation Rate (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period === 'Mar-16' || datum.period === 'Mar-26'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 190,
        "color": "#fff1b8",
        "stroke": "#0a0a0a",
        "strokeWidth": 2.5
      },
      "encoding": {
        "tooltip": [
          {
            "field": "period",
            "type": "nominal",
            "title": "Period"
          },
          {
            "field": "participation_rate",
            "type": "quantitative",
            "title": "Participation Rate (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period === 'Mar-16'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 12,
        "dy": -10,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#fff1b8"
      },
      "encoding": {
        "text": {
          "value": "64.9%"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period === 'Mar-26'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dx": -12,
        "dy": -12,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#fff1b8"
      },
      "encoding": {
        "text": {
          "value": "66.8%"
        }
      }
    }
  ],
  "config": {
    "background": "#161616",
    "font": "Source Sans 3",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "labelColor": "#d8d1c2",
      "titleColor": "#f4f1ea",
      "domainColor": "#4a4030",
      "tickColor": "#c9a961",
      "gridColor": "#383226",
      "gridOpacity": 0.65,
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "text": {
      "font": "Source Sans 3",
      "color": "#f4f1ea"
    }
  }
}