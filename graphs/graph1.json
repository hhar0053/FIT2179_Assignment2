{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "",
  "width": 640,
  "height": 420,
  "params": [
    {
      "name": "StateSelection",
      "value": "Victoria",
      "bind": {
        "input": "select",
        "options": [
          "New South Wales",
          "Victoria",
          "Queensland",
          "South Australia",
          "Western Australia",
          "Tasmania",
          "Northern Territory",
          "Australian Capital Territory"
        ],
        "name": "Select state: "
      }
    }
  ],
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "data/australia_sa2.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "calculate": "toString(datum.properties.SA2_CODE21)",
      "as": "sa2_code_lookup"
    },
    {
      "lookup": "sa2_code_lookup",
      "from": {
        "data": {
          "url": "data/sa2_unemployment_dec2025.csv",
          "format": {
            "type": "csv",
            "parse": {
              "sa2_code": "string",
              "unemployment_rate": "number",
              "unemployed_persons": "number",
              "labour_force": "number"
            }
          }
        },
        "key": "sa2_code",
        "fields": [
          "state",
          "sa2_name",
          "unemployment_rate",
          "unemployed_persons",
          "labour_force"
        ]
      }
    },
    {
      "filter": "datum.state == StateSelection"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "#6b6357",
    "strokeWidth": 0.5
  },
  "encoding": {
    "color": {
      "field": "unemployment_rate",
      "type": "quantitative",
      "title": "Unemployment rate (%)",
      "scale": {
        "range": ["#f0e6c8", "#d4b876", "#a8893f", "#6b5320", "#473615", "#2e2410"]
      },
      "legend": {
        "orient": "right",
        "gradientLength": 200,
        "gradientThickness": 10,
        "labelFontSize": 10,
        "titleFontSize": 11,
        "labelColor": "#c4bfb5",
        "titleColor": "#f4f1ea",
        "offset": 8,
        "padding": 6,
        "titleLimit": 200
      }
    },
    "tooltip": [
      {
        "field": "sa2_name",
        "type": "nominal",
        "title": "SA2 Region"
      },
      {
        "field": "state",
        "type": "nominal",
        "title": "State/Territory"
      },
      {
        "field": "unemployment_rate",
        "type": "quantitative",
        "title": "Unemployment rate (%)",
        "format": ".1f"
      },
      {
        "field": "unemployed_persons",
        "type": "quantitative",
        "title": "Unemployed persons",
        "format": ",.0f"
      },
      {
        "field": "labour_force",
        "type": "quantitative",
        "title": "Labour force",
        "format": ",.0f"
      }
    ]
  },
  "config": {
    "font": "Source Sans 3",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "labelColor": "#c4bfb5",
      "titleColor": "#f4f1ea",
      "domainColor": "#2a2a2a",
      "tickColor": "#a8a08e",
      "gridColor": "#222222",
      "gridOpacity": 0.5,
      "domainWidth": 1,
      "tickWidth": 1
    },
    "legend": {
      "orient": "right",
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "labelColor": "#c4bfb5",
      "titleColor": "#f4f1ea"
    },
    "text": {
      "font": "Source Sans 3",
      "color": "#f4f1ea"
    },
    "background": "#161616",
    "title": {
      "color": "#f4f1ea",
      "font": "Source Sans 3",
      "fontSize": 14
    }
  }
}